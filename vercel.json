{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    { "source": "/css/:path*", "destination": "/css/:path*" },
    { "source": "/login.php", "destination": "/api/login.php" },
    { "source": "/login", "destination": "/api/login.php" },
    { "source": "/register.php", "destination": "/api/register.php" },
    { "source": "/register", "destination": "/api/register.php" },
    { "source": "/dashboard.php", "destination": "/api/dashboard.php" },
    { "source": "/dashboard", "destination": "/api/dashboard.php" },
    { "source": "/tiket.php", "destination": "/api/tiket.php" },
    { "source": "/tiket", "destination": "/api/tiket.php" },
    { "source": "/tiket-harian.php", "destination": "/api/tiket_harian.php" },
    { "source": "/tiket-harian", "destination": "/api/tiket_harian.php" },
    { "source": "/tiket_harian.php", "destination": "/api/tiket_harian.php" },
    { "source": "/tiket_harian", "destination": "/api/tiket_harian.php" },
    { "source": "/logout.php", "destination": "/api/logout.php" },
    { "source": "/logout", "destination": "/api/logout.php" },
    { "source": "/landing_page.php", "destination": "/api/landing_page.php" },
    { "source": "/backup_tiket.php", "destination": "/api/backup_tiket.php" },
    { "source": "/", "destination": "/index.html" }
  ]
}