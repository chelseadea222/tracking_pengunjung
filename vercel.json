{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "^/login\\.php$", "dest": "/api/login.php" },
    { "src": "^/login$", "dest": "/api/login.php" },
    { "src": "^/register\\.php$", "dest": "/api/register.php" },
    { "src": "^/register$", "dest": "/api/register.php" },
    { "src": "^/dashboard\\.php$", "dest": "/api/dashboard.php" },
    { "src": "^/dashboard$", "dest": "/api/dashboard.php" },
    { "src": "^/tiket\\.php$", "dest": "/api/tiket.php" },
    { "src": "^/tiket$", "dest": "/api/tiket.php" },
    { "src": "^/tiket-harian\\.php$", "dest": "/api/tiket_harian.php" },
    { "src": "^/tiket-harian$", "dest": "/api/tiket_harian.php" },
    { "src": "^/tiket_harian\\.php$", "dest": "/api/tiket_harian.php" },
    { "src": "^/tiket_harian$", "dest": "/api/tiket_harian.php" },
    { "src": "^/logout\\.php$", "dest": "/api/logout.php" },
    { "src": "^/logout$", "dest": "/api/logout.php" },
    { "src": "^/landing_page\\.php$", "dest": "/api/landing_page.php" },
    { "src": "/(.*)", "dest": "/index.html", "status": 200 }
  ]
}